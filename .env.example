# URL backend Railway (tanpa trailing slash, TANPA /api di akhir)
# Contoh jika backend terpisah:
# VITE_API_URL=https://mata-se26-backend.up.railway.app
#
# Jika frontend dan backend satu service (monorepo Railway),
# biarkan kosong — Vite proxy akan menangani saat dev,
# dan Express akan serve /api langsung saat production.
VITE_API_URL=
